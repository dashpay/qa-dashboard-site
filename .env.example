# Build-time defaults baked into the bundle. All are optional and can be
# overridden at runtime by public/config.json or the in-app settings field.
#
# The dash-qa contract ID comes from the sibling "data contract + seed" task,
# which writes contract-id.testnet.json. Paste that id here (or set it as the
# CONTRACT_ID GitHub Actions secret/variable consumed by .github/workflows/deploy.yml).

VITE_CONTRACT_ID=
VITE_NETWORK=testnet
VITE_TESTCASE_DOC_TYPE=testCase
VITE_TESTRUN_DOC_TYPE=testRun

# Base path for the built site. Defaults to /qa-dashboard-site/ for GitHub Pages
# project hosting. Set to "/" for a custom domain or Vercel.
# VITE_BASE=/qa-dashboard-site/
